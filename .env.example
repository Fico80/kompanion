# ============================================================
# Local Assistant - Configuration
# Copy this file: cp .env.example .env
# ============================================================

# --- STT (Speech Input) ---
# Option A: whisper.cpp local (no key needed, whisper-server must be running)
# See docs/LOCAL_AI.md and README.md for setup instructions
# WHISPER_BASE_URL=http://127.0.0.1:8081
# WHISPER_LANGUAGE=en    # transcription language (en, de, fr, ...)

# Option B: Cloud STT (Groq, OpenAI, or any OpenAI-compatible provider)
# STT_BASE_URL=https://api.groq.com/openai/v1   # provider base URL
# STT_API_KEY=                                   # API key
# STT_MODEL=                                     # model name (default: whisper-large-v3-turbo)

# --- LLM (Command Understanding / Fallback) ---
# Option A: Ollama or llama.cpp local (no key needed, server must be running)
# See docs/LOCAL_AI.md and README.md for setup instructions
# LLM_BASE_URL=http://127.0.0.1:11434/v1   # Ollama
# LLM_BASE_URL=http://127.0.0.1:8080/v1    # llama.cpp
# LLM_MODEL=qwen2.5:7b

# Option B: Any OpenAI-compatible cloud API (OpenAI, Groq, Together AI, ...)
# LLM_API_KEY=           # API key
# LLM_BASE_URL=          # provider endpoint, e.g. https://api.openai.com/v1
# LLM_MODEL=             # model name as required by the provider

# --- Spotify (optional) ---
# Create app: https://developer.spotify.com/dashboard
# Add redirect URI: http://127.0.0.1:8000/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Google Calendar (optional) ---
# Create OAuth app: https://console.cloud.google.com/
# Add redirect URI: http://127.0.0.1:8000/calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- TTS (Text-to-Speech) ---
# Piper is used for local neural TTS. espeak-ng is the fallback when no model is configured.
# Download models: https://huggingface.co/rhasspy/piper-voices/tree/main
# See README.md for wget commands.
# PIPER_MODEL_EN=~/.local/share/piper/en_US-lessac-medium.onnx
# PIPER_MODEL_DE=~/.local/share/piper/de_DE-thorsten-medium.onnx
# Or a single model for all languages:
# PIPER_MODEL=~/.local/share/piper/en_US-lessac-medium.onnx

# --- Voice Recording ---
# MAX_RECORD_SECONDS=300       # safety cap for a single recording (default: 300 s); recording ends on silence before this

# --- HUD ---
# HUD_STYLE=kompanion          # HUD style: kompanion (default), pill, mini
# HUD_POSITION=bottom-right    # HUD position: bottom-right (default), bottom-left, top-right, top-left,
#                              #               bottom-center, top-center, center, center-left, center-right

# --- Embeddings (note similarity search) ---
# EMBED_BASE_URL=http://localhost:11434/v1   # Ollama or any OpenAI-compatible embeddings endpoint
# EMBED_MODEL=nomic-embed-text               # embedding model (must match LLM_BASE_URL provider)
# EMBED_API_KEY=                             # optional, falls back to LLM_API_KEY for cloud providers
# Without EMBED_BASE_URL, note search falls back to substring matching.
# Note: switching models invalidates existing embeddings — old notes fall back to substring match.

# --- Notes ---
# NOTES_DIR=~/Notes              # folder where voice notes are saved (default: ~/Notes)
# Tip: for dictating or editing notes, push-to-talk (Right Ctrl) is recommended.
#      First press starts recording, second press stops and processes.
#      This lets you dictate longer notes without a time limit.

# --- Monitor Brightness (ddcutil) ---
# DDCUTIL_LEFT_DISPLAY=1       # display index for left monitor (default: 1)
# DDCUTIL_RIGHT_DISPLAY=2      # display index for right monitor (default: 2)

# --- Wake-Word (openWakeWord) ---
# WAKE_WORD_ENABLED=1          # enable always-on wake-word mode
# WAKE_WORD=hey_jarvis_v0.1    # model name (hey_jarvis_v0.1, alexa_v0.1, hey_mycroft_v0.1)
# WAKE_WORD_THRESHOLD=0.60     # detection sensitivity - higher = fewer false positives (0.0-1.0)
# WAKE_CONSECUTIVE_BLOCKS=2    # consecutive hits before wake fires (reduces false triggers)
# WAKE_FAILED_REARM_SECONDS=2nein   # cooldown after wake with no speech detected
# WAKE_REQUIRE_VAD=1           # only count wake scores when voice activity is detected
# WAKE_VAD_GRACE_BLOCKS=6      # how many 80ms blocks voice activity stays open after speech ends
# WAKE_DEBUG=0                 # log ignored wake scores for tuning
# WAKE_SILENCE_SECONDS=2.0     # seconds of silence before processing starts (default: 2.0)
# WAKE_SESSION_TIMEOUT=5       # seconds the assistant stays active after last command
# WAKE_LOCAL_WAIT_SECONDS=30   # how long "wait a moment" keeps the session open

# --- Hotkey ---
# HOTKEY_KEY=KEY_RIGHTCTRL   # push-to-talk key (default: KEY_RIGHTCTRL); use evdev key names, e.g. KEY_LEFTCTRL, KEY_F9

# --- Media ---
# VOICE_PAUSE_MEDIA_ON_TRIGGER=1   # pause playing media when recording starts
# VOICE_RESUME_MEDIA_ON_SLEEP=1    # resume media when assistant goes back to sleep
